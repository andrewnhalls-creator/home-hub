# Next.js application environment variables (.env.local — never commit)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Supabase Edge Function secrets — set via Supabase dashboard or CLI, NOT here
